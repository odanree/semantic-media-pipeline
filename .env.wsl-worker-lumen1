# ============================================================================
# WSL2 Native Celery Worker — lumen1 stack
# ============================================================================
# PREREQUISITE: Add host ports for lumen1 Redis and Postgres in docker-compose.yml
# (already done — see ports: 6379:6379 on redis, 15432:5432 on postgres)
# Then: docker compose up -d redis postgres
#
# Start (inside WSL2):
#   cd /mnt/c/Users/<user>/Projects/semantic-media-pipeline
#   bash scripts/start-wsl-worker-lumen1.sh
# ============================================================================

# ---------------------------------------------------------------------------
# Celery / Redis — lumen1 Redis exposed on host port 6379
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# PostgreSQL — lumen1 Postgres exposed on host port 5432
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://lumen_user:lumen_secure_password_2026@localhost:15432/lumen
DATABASE_ASYNC_URL=postgresql+asyncpg://lumen_user:lumen_secure_password_2026@localhost:15432/lumen

# ---------------------------------------------------------------------------
# Qdrant — lumen1 Qdrant exposed on host port 6333
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=true
QDRANT_COLLECTION_NAME=media_vectors

# ---------------------------------------------------------------------------
# Media paths
# Source is symlinked: /mnt/source → /mnt/j/lumen-media (see setup script)
# Frame cache:         /mnt/frame_cache → /mnt/j/frame_cache
# MEDIA_ROOT is a Windows bind-mount path (same dir Docker API uses)
# ---------------------------------------------------------------------------
MEDIA_ROOT=/mnt/c/Users/<user>/Projects/semantic-media-pipeline/data/media
FRAME_CACHE_DIR=/mnt/j/frame_cache
PROXY_ROOT=/tmp/lumen1-proxies
STORAGE_BACKEND=local

# ---------------------------------------------------------------------------
# CLIP model & GPU
# ---------------------------------------------------------------------------
CLIP_MODEL_NAME=clip-ViT-L-14
EMBEDDING_BATCH_SIZE=96
EMBEDDING_DEVICE=

# ---------------------------------------------------------------------------
# Celery worker tuning
# ---------------------------------------------------------------------------
CELERY_CONCURRENCY=2
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_MAX_TASKS_PER_CHILD=50
CELERY_MAX_MEMORY_PER_CHILD=8000000

# ---------------------------------------------------------------------------
# FFmpeg / frame extraction
# ---------------------------------------------------------------------------
KEYFRAME_FPS=0.5
KEYFRAME_RESOLUTION=224
FFMPEG_TIMEOUT=86400

# ---------------------------------------------------------------------------
# Worker identity
# ---------------------------------------------------------------------------
WORKER_ID=wsl-native-lumen1
WORKER_HOSTNAME=wsl-lumen1@%h

# ---------------------------------------------------------------------------
# Python / DirectML environment
# ---------------------------------------------------------------------------
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
LD_LIBRARY_PATH=/usr/lib/wsl/lib

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
LOG_LEVEL=info
