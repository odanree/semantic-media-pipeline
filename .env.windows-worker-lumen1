# ============================================================================
# Windows Native Celery Worker — lumen1 stack
# ============================================================================
# Run with:  scripts\start-windows-worker-lumen1.ps1
# ============================================================================

# ---------------------------------------------------------------------------
# Celery / Redis — lumen1 Redis exposed on host port 6379
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# PostgreSQL — lumen1 Postgres exposed on host port 15432
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://lumen_user:lumen_secure_password_2026@localhost:15432/lumen
DATABASE_ASYNC_URL=postgresql+asyncpg://lumen_user:lumen_secure_password_2026@localhost:15432/lumen

# ---------------------------------------------------------------------------
# Qdrant — lumen1 Qdrant exposed on host port 6333/6334
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=false
QDRANT_COLLECTION_NAME=media_vectors

# ---------------------------------------------------------------------------
# Media paths (Windows-native, J: = lumen-media)
# ---------------------------------------------------------------------------
MEDIA_ROOT=C:\Users\<user>\Projects\semantic-media-pipeline\data\media
FRAME_CACHE_DIR=J:\frame_cache
PROXY_ROOT=J:\lumen1-proxies
STORAGE_BACKEND=local

# ---------------------------------------------------------------------------
# Path translation: Docker/Linux paths stored in DB → Windows paths on disk
# Format: LUMEN_PATH_MAP_n=/linux/prefix:C:/win/path
# ---------------------------------------------------------------------------
LUMEN_PATH_MAP_0=/mnt/source:J:/lumen-media

# ---------------------------------------------------------------------------
# CLIP model & GPU
# ---------------------------------------------------------------------------
CLIP_MODEL_NAME=clip-ViT-L-14
EMBEDDING_BATCH_SIZE=256
EMBEDDING_DEVICE=cuda
WHISPER_DEVICE=cuda

# ---------------------------------------------------------------------------
# Celery worker tuning
# ---------------------------------------------------------------------------
CELERY_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_MAX_TASKS_PER_CHILD=50
CELERY_MAX_MEMORY_PER_CHILD=8000000

# ---------------------------------------------------------------------------
# FFmpeg / frame extraction
# ---------------------------------------------------------------------------
KEYFRAME_FPS=0.5
KEYFRAME_RESOLUTION=224
FFMPEG_TIMEOUT=86400

# ---------------------------------------------------------------------------
# Worker identity
# ---------------------------------------------------------------------------
WORKER_ID=win-native-lumen1

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
LOG_LEVEL=info
