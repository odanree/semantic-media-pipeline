# ============================================================================
# WSL2 Native Celery Worker — lumen2 stack
# ============================================================================
# Run this worker INSTEAD of the Docker lumen2-worker container.
# All service ports are already exposed on localhost by docker-compose.second.yml.
#
# Start (inside WSL2):
#   cd /mnt/c/Users/<user>/Projects/semantic-media-pipeline
#   bash scripts/start-wsl-worker-lumen2.sh
# ============================================================================

# ---------------------------------------------------------------------------
# Celery / Redis — lumen2 Redis exposed on host port 6380
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0
REDIS_URL=redis://localhost:6380

# ---------------------------------------------------------------------------
# PostgreSQL — lumen2 Postgres exposed on host port 5433
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://lumen2_user:lumen_secure_password_2026@localhost:5433/lumen2
DATABASE_ASYNC_URL=postgresql+asyncpg://lumen2_user:lumen_secure_password_2026@localhost:5433/lumen2

# ---------------------------------------------------------------------------
# Qdrant — lumen2 Qdrant exposed on host port 6340/6341
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6340
QDRANT_GRPC_PORT=6341
QDRANT_PREFER_GRPC=true
QDRANT_COLLECTION_NAME=media_vectors2

# ---------------------------------------------------------------------------
# Media paths
# Source files are symlinked in WSL2 (see setup-wsl-worker.sh):
#   /mnt/source/e           → /mnt/e/Unsorted
#   /mnt/source/f-downloads → /mnt/c/Users/<user>/Downloads/<media-folder>
# MEDIA_ROOT stores thumbnails — written to a local WSL2 dir.
# (Note: lumen2-api serves thumbnails from its Docker volume, not this path.
#  Thumbnails from this worker won't appear in lumen2 UI until media2_data
#  is converted to a bind mount. CLIP embeddings in Qdrant work immediately.)
# ---------------------------------------------------------------------------
MEDIA_ROOT=/home/$USER/lumen2-media
FRAME_CACHE_DIR=/mnt/i/lumen2-frame-cache
PROXY_ROOT=/tmp/lumen2-proxies
STORAGE_BACKEND=local

# ---------------------------------------------------------------------------
# CLIP model & GPU
# EMBEDDING_DEVICE left blank → auto-detect (DirectML > CUDA > CPU)
# DirectML requires /dev/dxg in WSL2 and torch-directml installed (see setup script)
# ---------------------------------------------------------------------------
CLIP_MODEL_NAME=clip-ViT-L-14
EMBEDDING_BATCH_SIZE=96
EMBEDDING_DEVICE=

# ---------------------------------------------------------------------------
# Celery worker tuning
# Start with concurrency=2 to stay within VRAM budget; raise if stable.
# 20GB VRAM, ViT-L-14 ~3-4GB per process → max ~4 concurrent safely.
# ---------------------------------------------------------------------------
CELERY_CONCURRENCY=2
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_MAX_TASKS_PER_CHILD=50
CELERY_MAX_MEMORY_PER_CHILD=8000000

# ---------------------------------------------------------------------------
# FFmpeg / frame extraction
# ---------------------------------------------------------------------------
KEYFRAME_FPS=0.5
KEYFRAME_RESOLUTION=224
FFMPEG_TIMEOUT=86400

# ---------------------------------------------------------------------------
# Worker identity
# ---------------------------------------------------------------------------
WORKER_ID=wsl-native-lumen2
WORKER_HOSTNAME=wsl-lumen2@%h

# ---------------------------------------------------------------------------
# Python / DirectML environment
# ---------------------------------------------------------------------------
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
LD_LIBRARY_PATH=/usr/lib/wsl/lib
LIBDXCORE_LIBRARY=/usr/lib/wsl/lib/libdxcore.so

# ---------------------------------------------------------------------------
# Misc (not needed for worker, silences startup warnings)
# ---------------------------------------------------------------------------
LOG_LEVEL=info
