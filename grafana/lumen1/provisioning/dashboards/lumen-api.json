{
  "title": "Lumen API Performance",
  "uid": "lumen-api-perf",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "lumen-prometheus" },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_request_duration_seconds_count{job=\"lumen2-api\"}[2m]))",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "P95 Latency by Endpoint (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "lumen-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{job=\"lumen2-api\"}[5m])))",
          "legendFormat": "p95 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "P50 Latency by Endpoint (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "lumen-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (handler, le) (rate(http_request_duration_seconds_bucket{job=\"lumen2-api\"}[5m])))",
          "legendFormat": "p50 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "Error Rate (4xx + 5xx req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "lumen-prometheus" },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_request_duration_seconds_count{job=\"lumen2-api\", status_code=~\"4..|5..\"}[2m]))",
          "legendFormat": "errors {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "title": "Playlist Generation Duration (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "uid": "lumen-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"lumen2-api\", handler=\"/api/playlist\"}[10m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"lumen2-api\", handler=\"/api/playlist\"}[10m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "rate(http_request_duration_seconds_sum{job=\"lumen2-api\", handler=\"/api/playlist\"}[5m]) / rate(http_request_duration_seconds_count{job=\"lumen2-api\", handler=\"/api/playlist\"}[5m])",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    }
  ]
}
