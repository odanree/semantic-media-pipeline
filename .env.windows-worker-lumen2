# ============================================================================
# Windows Native Celery Worker — lumen2 stack
# ============================================================================
# Run with:  scripts\start-windows-worker-lumen2.ps1
# ============================================================================

# ---------------------------------------------------------------------------
# Celery / Redis — lumen2 Redis exposed on host port 6380
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0
REDIS_URL=redis://localhost:6380

# ---------------------------------------------------------------------------
# PostgreSQL — lumen2 Postgres exposed on host port 5433
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://lumen2_user:lumen_secure_password_2026@localhost:5433/lumen2
DATABASE_ASYNC_URL=postgresql+asyncpg://lumen2_user:lumen_secure_password_2026@localhost:5433/lumen2

# ---------------------------------------------------------------------------
# Qdrant — lumen2 Qdrant exposed on host port 6340/6341
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6340
QDRANT_GRPC_PORT=6341
QDRANT_PREFER_GRPC=true
QDRANT_COLLECTION_NAME=media_vectors2

# ---------------------------------------------------------------------------
# Media paths (Windows-native, I: = Sabrent V2)
# ---------------------------------------------------------------------------
MEDIA_ROOT=I:\lumen2-media
FRAME_CACHE_DIR=I:\lumen2-frame-cache
PROXY_ROOT=I:\lumen2-proxies
STORAGE_BACKEND=local

# ---------------------------------------------------------------------------
# Path translation: Docker/Linux paths stored in DB → Windows paths on disk
# Format: LUMEN_PATH_MAP_n=/linux/prefix:C:/win/path
# Processed longest-prefix-first; forward slashes work on Windows in Python.
# ---------------------------------------------------------------------------
LUMEN_PATH_MAP_0=/mnt/source/e:E:/Unsorted
LUMEN_PATH_MAP_1=/mnt/source/f-downloads:C:/Users/<user>/Downloads/<media-folder>

# ---------------------------------------------------------------------------
# CLIP model & GPU
# ---------------------------------------------------------------------------
CLIP_MODEL_NAME=clip-ViT-L-14
EMBEDDING_BATCH_SIZE=256
EMBEDDING_DEVICE=cuda
WHISPER_DEVICE=cuda

# ---------------------------------------------------------------------------
# Celery worker tuning
# ViT-L-14 uses ~3-4GB VRAM per process; 20GB VRAM → safe at concurrency=4
# Reduced to 2 when running alongside lumen1 worker to avoid RAM pressure
# ---------------------------------------------------------------------------
CELERY_CONCURRENCY=2
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_MAX_TASKS_PER_CHILD=50
CELERY_MAX_MEMORY_PER_CHILD=8000000

# ---------------------------------------------------------------------------
# FFmpeg / frame extraction
# ---------------------------------------------------------------------------
KEYFRAME_FPS=0.5
KEYFRAME_RESOLUTION=224
FFMPEG_TIMEOUT=86400

# ---------------------------------------------------------------------------
# Worker identity
# ---------------------------------------------------------------------------
WORKER_ID=win-native-lumen2

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
LOG_LEVEL=info
