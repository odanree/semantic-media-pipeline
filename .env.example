# ============================================================================
# Environment Configuration for Lumen - Semantic Media Pipeline
# ============================================================================
# Copy this file to .env and fill in your values

# Suppress docker compose interactive prompts (e.g. volume recreate warnings)
COMPOSE_INTERACTIVE_NO_CLI=1

# ============================================================================
# Celery / Redis Configuration
# ============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# Qdrant Vector Database Configuration
# ============================================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# Use gRPC for faster performance if available
QDRANT_PREFER_GRPC=true
QDRANT_COLLECTION_NAME=media_vectors

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=lumen
DATABASE_USER=lumen_user
DATABASE_PASSWORD=secure_password_here
DATABASE_URL=postgresql://lumen_user:secure_password_here@postgres:5432/lumen

# For async operations
DATABASE_ASYNC_URL=postgresql+asyncpg://lumen_user:secure_password_here@postgres:5432/lumen

# ============================================================================
# Media Ingestion Configuration
# ============================================================================
# MEDIA_SOURCE_PATH: Host path to your source media library.
# Mounted read-only inside containers at /mnt/source.
# Windows example: J:/    Linux example: /mnt/media
MEDIA_SOURCE_PATH=/path/to/your/media

# MEDIA_ROOT: Host path for processed output (thumbnails, normalized frames).
# This is a bind mount — its contents survive docker compose down -v.
# Windows example: C:/Users/you/Projects/Semantic-Media-Pipeline/data/media
MEDIA_ROOT=./data/media

# Storage backend: 'local' | 's3' | 'gcs'
STORAGE_BACKEND=local

# ============================================================================
# S3 Configuration (if STORAGE_BACKEND=s3)
# Supports AWS S3, Cloudflare R2, MinIO, or any S3-compatible endpoint.
# The worker code uses boto3 — only the endpoint URL changes per provider.
# ============================================================================

# --- Option A: Cloudflare R2 (10GB free forever, zero egress cost) ---
# 1. Create R2 bucket at dash.cloudflare.com > R2
# 2. Create API token with Object Read & Write permissions
# 3. Find your account ID at the R2 overview page
#S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#S3_BUCKET=lumen-media-demo
#S3_ACCESS_KEY=<R2_ACCESS_KEY_ID>
#S3_SECRET_KEY=<R2_SECRET_ACCESS_KEY>
#S3_REGION=auto

# --- Option B: Local MinIO (default, no cloud required) ---
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# --- Option C: AWS S3 ---
#S3_ENDPOINT_URL=
#S3_BUCKET=your-bucket-name
#S3_ACCESS_KEY=AKIA...
#S3_SECRET_KEY=...
#S3_REGION=us-east-1

# ============================================================================
# Google Cloud Storage Configuration (if STORAGE_BACKEND=gcs)
# ============================================================================
GCS_PROJECT_ID=your-gcp-project
GCS_BUCKET=your-gcs-bucket
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs_key.json

# ============================================================================
# GPU Configuration
# ============================================================================
# CUDA device IDs to use (comma-separated, or empty for auto)
CUDA_VISIBLE_DEVICES=
# Manually enable/disable CUDA
USE_CUDA=true

# ============================================================================
# FFmpeg Configuration
# ============================================================================
# Temporal sampling: frames per second
KEYFRAME_FPS=0.5
# Target frame resolution for CLIP encoding
KEYFRAME_RESOLUTION=224
# FFmpeg timeout in seconds for frame extraction (default 1200 = 20 minutes)
# Automatically scaled based on video duration + I/O overhead
# Increase if experiencing "FFmpeg timeout" errors on longer videos
FFMPEG_TIMEOUT=1200
# Frame extraction cache — centralized on the Windows host, shared to Mac over SMB.
# Cache key: sha256(file_hash + fps + resolution) — model-agnosic, survives CLIP upgrades.
# On re-index after a model upgrade, ffmpeg extraction is skipped entirely (cache HIT).
# Windows host path (set this in your .env):
#   FRAME_CACHE_DIR=D:\lumen_frame_cache   (or any drive with enough space)
# Mac worker mounts the same dir via: /Volumes/lumen-media-1/frame_cache
# Clear by deleting contents of this folder — only needed if FPS or RESOLUTION changes.
FRAME_CACHE_DIR=/tmp/lumen_frame_cache

# ============================================================================
# CLIP Model Configuration
# ============================================================================
# sentence-transformers model name
CLIP_MODEL_NAME=clip-ViT-L-14
# Batch size for frame embedding (reduce for ViT-L-14 — larger model)
EMBEDDING_BATCH_SIZE=16
# Device for embeddings
EMBEDDING_DEVICE=cuda

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# FastAPI log level
LOG_LEVEL=info

# ============================================================================
# Frontend Configuration
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_QDRANT_HOST=localhost
NEXT_PUBLIC_QDRANT_PORT=6333

# ============================================================================
# Observability
# ============================================================================
# Flower (Celery monitoring)
FLOWER_PORT=5555
FLOWER_BROKER=redis://redis:6379/0

# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================================================
# Development
# ============================================================================
DEBUG=false
ENVIRONMENT=development
