# ============================================================================
# Environment Configuration for Lumen - Semantic Media Pipeline
# ============================================================================
# Copy this file to .env and fill in your values

# Suppress docker compose interactive prompts (e.g. volume recreate warnings)
COMPOSE_INTERACTIVE_NO_CLI=1

# ============================================================================
# Celery / Redis Configuration
# ============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# Qdrant Vector Database Configuration
# ============================================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# Use gRPC for faster performance if available
QDRANT_PREFER_GRPC=true
QDRANT_COLLECTION_NAME=media_vectors

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=lumen
DATABASE_USER=lumen_user
DATABASE_PASSWORD=secure_password_here
DATABASE_URL=postgresql://lumen_user:secure_password_here@postgres:5432/lumen

# For async operations
DATABASE_ASYNC_URL=postgresql+asyncpg://lumen_user:secure_password_here@postgres:5432/lumen

# ============================================================================
# Media Ingestion Configuration
# ============================================================================
# MEDIA_SOURCE_PATH: Host path to your source media library.
# Mounted read-only inside containers at /mnt/source.
# Windows example: J:/    Linux example: /mnt/media
MEDIA_SOURCE_PATH=/path/to/your/media

# MEDIA_ROOT: Host path for processed output (thumbnails, normalized frames).
# This is a bind mount — its contents survive docker compose down -v.
# Windows example: C:/Users/you/Projects/Semantic-Media-Pipeline/data/media
MEDIA_ROOT=./data/media

# Storage backend: 'local' | 's3' | 'gcs'
STORAGE_BACKEND=local

# ============================================================================
# S3 Configuration (if STORAGE_BACKEND=s3)
# ============================================================================
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ============================================================================
# Google Cloud Storage Configuration (if STORAGE_BACKEND=gcs)
# ============================================================================
GCS_PROJECT_ID=your-gcp-project
GCS_BUCKET=your-gcs-bucket
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs_key.json

# ============================================================================
# GPU Configuration
# ============================================================================
# CUDA device IDs to use (comma-separated, or empty for auto)
CUDA_VISIBLE_DEVICES=
# Manually enable/disable CUDA
USE_CUDA=true

# ============================================================================
# FFmpeg Configuration
# ============================================================================
# Temporal sampling: frames per second
KEYFRAME_FPS=0.5
# Target frame resolution for CLIP encoding
KEYFRAME_RESOLUTION=224

# ============================================================================
# CLIP Model Configuration
# ============================================================================
# sentence-transformers model name
CLIP_MODEL_NAME=clip-ViT-B-32
# Batch size for frame embedding
EMBEDDING_BATCH_SIZE=32
# Device for embeddings
EMBEDDING_DEVICE=cuda

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# FastAPI log level
LOG_LEVEL=info

# ============================================================================
# Frontend Configuration
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_QDRANT_HOST=localhost
NEXT_PUBLIC_QDRANT_PORT=6333

# ============================================================================
# Observability
# ============================================================================
# Flower (Celery monitoring)
FLOWER_PORT=5555
FLOWER_BROKER=redis://redis:6379/0

# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================================================
# Development
# ============================================================================
DEBUG=false
ENVIRONMENT=development
