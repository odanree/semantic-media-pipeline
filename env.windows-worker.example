# =
# Windows Native Celery Worker — lumen1 stack
# =
# Run with:  scripts\start-windows-worker-lumen1.ps1
# =

# ---------------------------------------------------------------------------
# Celery / Redis — lumen1 Redis exposed on host port 6379
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
REDIS_URL=

# ---------------------------------------------------------------------------
# PostgreSQL — lumen1 Postgres exposed on host port 15432
# ---------------------------------------------------------------------------
DATABASE_URL=
DATABASE_ASYNC_URL=

# ---------------------------------------------------------------------------
# Qdrant — lumen1 Qdrant exposed on host port 6333/6334
# ---------------------------------------------------------------------------
QDRANT_HOST=
QDRANT_PORT=
QDRANT_GRPC_PORT=
QDRANT_PREFER_GRPC=
QDRANT_COLLECTION_NAME=

# ---------------------------------------------------------------------------
# Media paths (Windows-native, J: =
# ---------------------------------------------------------------------------
MEDIA_ROOT=
FRAME_CACHE_DIR=
PROXY_ROOT=
STORAGE_BACKEND=

# ---------------------------------------------------------------------------
# Path translation: Docker/Linux paths stored in DB → Windows paths on disk
# Format: LUMEN_PATH_MAP_n=
# ---------------------------------------------------------------------------
LUMEN_PATH_MAP_0=

# ---------------------------------------------------------------------------
# CLIP model & GPU
# ---------------------------------------------------------------------------
CLIP_MODEL_NAME=
EMBEDDING_BATCH_SIZE=
EMBEDDING_DEVICE=
WHISPER_DEVICE=

# ---------------------------------------------------------------------------
# Celery worker tuning
# ---------------------------------------------------------------------------
CELERY_CONCURRENCY=
CELERY_WORKER_PREFETCH_MULTIPLIER=
CELERY_MAX_TASKS_PER_CHILD=
CELERY_MAX_MEMORY_PER_CHILD=

# ---------------------------------------------------------------------------
# FFmpeg / frame extraction
# ---------------------------------------------------------------------------
KEYFRAME_FPS=
KEYFRAME_RESOLUTION=
FFMPEG_TIMEOUT=

# ---------------------------------------------------------------------------
# Worker identity
# ---------------------------------------------------------------------------
WORKER_ID=

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
PYTHONUNBUFFERED=
PYTHONDONTWRITEBYTECODE=
LOG_LEVEL=
