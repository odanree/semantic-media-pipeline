# Backend API Configuration
# Development: http://localhost:8000 (when running API locally)
# Docker Compose: http://api:8000 (when running in containers)
# Production: https://api.yourdomain.com
API_URL=http://localhost:8000

# Backend API key — must match API_KEY in the FastAPI .env
# Leave empty to run without auth (default for local dev and public demo)
# Set to a strong random string to enable API key authentication
BACKEND_API_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000
